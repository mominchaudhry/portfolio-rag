# --- Ask My Portfolio (portfolio-rag) ---
# Copy to .env.local and fill in. .env.local is gitignored; never commit real keys.

# Vercel AI Gateway — primary model access (S1.5 decision). Routes BOTH embeddings
# (openai/text-embedding-3-small) and S3 answers (anthropic/claude-sonnet-4-6) through
# one key, with cost/latency telemetry + provider fallbacks. Create a key at:
# https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=

# Direct provider keys — OPTIONAL fallback if not using the gateway. The ingest/query
# scripts and S3 route through AI_GATEWAY_API_KEY above; these are not required.
# Anthropic (answers): https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# OpenAI (embeddings): https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Neon Postgres + pgvector — vector store. Free tier.
# Pooled connection string from the Neon dashboard. Run `CREATE EXTENSION vector;` once.
# https://neon.tech
DATABASE_URL=
