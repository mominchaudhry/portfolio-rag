# --- Ask My Portfolio (portfolio-rag) ---
# Copy to .env.local and fill in. .env.local is gitignored; never commit real keys.

# Anthropic — answer generation (claude-sonnet-4-6). Prepaid credits required.
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — embeddings (text-embedding-3-small). Prepaid credits required.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Neon Postgres + pgvector — vector store. Free tier.
# Pooled connection string from the Neon dashboard. Run `CREATE EXTENSION vector;` once.
# https://neon.tech
DATABASE_URL=
